# LibreChat Configuration - Complete Example
# This file contains ALL possible configuration
# Copy it and adapt it according to your needs

version: 1.3.13

cache: true

interface:
  customWelcome: 'Welcome to LibreChat!'
  fileSearch: true
  privacyPolicy:
    externalUrl: ''
    openNewTab: false
  termsOfService:
    externalUrl: ''
    openNewTab: false
  modelSelect: true
  parameters: true
  presets: true
  prompts:
    use: true
    create: true
    share: false
    public: false
  bookmarks: true
  multiConvo: true
  agents:
    use: true
    create: true
    share: false
    public: false
  peoplePicker:
    users: true
    groups: true
    roles: true
  marketplace:
    use: false
  fileCitations: true

# Cloudflare Turnstile
# IMPORTANT: Replace YOUR_SITE_KEY with your real Cloudflare Turnstile site key
# Get it at: https://dash.cloudflare.com/turnstile
turnstile:
  siteKey: 'YOUR_SITE_KEY'
  options:
    language: "ca"
    size: "normal"

registration:
  socialLogins: []
  # allowedDomains:
  #   - "yourdomain.com"

# Speech (TTS/STT)
speech:
  tts:
    localai:
      url: 'http://localai:8080'
      apiKey: ''
      model: 'tts-1'
      backend: 'piper'
      voices:
        - 'ca_ES-upc_ona-medium'
        - 'ca_ES-upc_pau-medium'
        - 'es_ES-sharvard-medium'
        - 'es_ES-davefx-medium'
        - 'en_US-amy-medium'
        - 'en_US-joe-medium'
        - 'fr_FR-siwis-medium'
        - 'fr_FR-gilles-medium'
        - 'it_IT-paola-medium'
        - 'it_IT-riccardo-medium'
  stt:
    openai:
      url: 'http://localai:8080/v1'
      apiKey: ''
      model: 'whisper-1'
  speechTab:
    textToSpeech: true
    speechToText: true
    autoSendSpeech: true
    preferredVoice: 'ca_ES-upc_ona-medium'

# Web Search Configuration
webSearch:
  searchProvider: searxng
  searxngInstanceUrl: '${SEARXNG_INSTANCE_URL}'
  scraperProvider: tavily
  tavilyApiKey: '${TAVILY_API_KEY}'
  rerankerType: jina
  jinaApiKey: '${JINA_API_KEY}'

endpoints:
  agents:
    recursionLimit: 25
    maxRecursionLimit: 50
    capabilities: ["file_search", "actions", "tools"]

  custom:
    # Anthropic (Claude)
    - name: 'Anthropic'
      apiKey: '${ANTHROPIC_API_KEY}'
      baseURL: 'https://api.anthropic.com/v1'
      models:
        default:
          - 'claude-3-5-sonnet-20241022'
          - 'claude-3-5-haiku-20241022'
          - 'claude-3-opus-20240229'
          - 'claude-3-sonnet-20240229'
          - 'claude-3-haiku-20240307'
        fetch: false
      titleConvo: true
      titleModel: 'claude-3-haiku-20240307'
      modelDisplayLabel: 'Anthropic'

    # OpenAI
    - name: 'OpenAI'
      apiKey: '${OPENAI_API_KEY}'
      baseURL: 'https://api.openai.com/v1'
      models:
        default:
          - 'gpt-4o'
          - 'gpt-4o-mini'
          - 'gpt-4-turbo'
          - 'gpt-4'
          - 'gpt-3.5-turbo'
          - 'o1-preview'
          - 'o1-mini'
        fetch: false
      titleConvo: true
      titleModel: 'gpt-3.5-turbo'
      modelDisplayLabel: 'OpenAI'

    # Qwen / DashScope (Alibaba Cloud)
    - name: 'Qwen'
      apiKey: '${QWEN_API_KEY}'
      baseURL: 'https://dashscope-intl.aliyuncs.com/compatible-mode/v1'
      models:
        default:
          - 'qwen-max'
          - 'qwen-plus'
          - 'qwen-turbo'
          - 'qwen-long'
          - 'qwen-coder-plus'
          - 'qwen-coder-turbo'
          - 'qwen-vl-max'
          - 'qwen-vl-plus'
        fetch: true
      titleConvo: true
      titleModel: 'qwen-turbo'
      modelDisplayLabel: 'Qwen'
      dropParams: ['stop', 'user', 'frequency_penalty', 'presence_penalty']

    # DeepSeek
    - name: 'DeepSeek'
      apiKey: '${DEEPSEEK_API_KEY}'
      baseURL: 'https://api.deepseek.com/v1'
      models:
        default:
          - 'deepseek-chat'
          - 'deepseek-reasoner'
        fetch: false
      titleConvo: true
      titleModel: 'deepseek-chat'
      modelDisplayLabel: 'DeepSeek'
      dropParams: ['stop', 'user', 'frequency_penalty', 'presence_penalty']

    # Zhipu AI / GLM
    - name: 'Zhipu AI'
      apiKey: '${ZHIPU_API_KEY}'
      baseURL: 'https://open.bigmodel.cn/api/paas/v4'
      models:
        default:
          - 'glm-4-plus'
          - 'glm-4-air'
          - 'glm-4-flash'
          - 'glm-4-long'
          - 'glm-4v-plus'
          - 'glm-4v'
          - 'cogview-4'
        fetch: false
      titleConvo: true
      titleModel: 'glm-4-flash'
      modelDisplayLabel: 'Zhipu AI'
      dropParams: ['stop', 'user', 'frequency_penalty', 'presence_penalty']

    # Ollama (local models)
    - name: 'Ollama'
      apiKey: 'ollama'
      baseURL: 'http://ollama:11434/v1/'
      models:
        default:
          - 'llama3.2'
          - 'mistral'
          - 'qwen2.5'
          - 'deepseek-r1'
          - 'codellama'
        fetch: true
      titleConvo: true
      titleModel: 'current_model'
      modelDisplayLabel: 'Ollama (Local)'

    # OpenRouter (multi-provider gateway)
    - name: 'OpenRouter'
      apiKey: '${OPENROUTER_KEY}'
      baseURL: 'https://openrouter.ai/api/v1'
      models:
        default:
          - 'meta-llama/llama-3.1-70b-instruct'
          - 'deepseek/deepseek-chat'
        fetch: true
      titleConvo: true
      titleModel: 'meta-llama/llama-3.1-70b-instruct'
      modelDisplayLabel: 'OpenRouter'
      dropParams: ['stop']

  allowedAddresses:
    - 'ollama:11434'
    - 'localhost:11434'
    - '127.0.0.1:11434'
    - 'host.docker.internal:11434'

# MCP Servers
mcpServers:
  qwen-image:
    type: stdio
    command: node
    args:
      - '/app/mcp-servers/qwen-image/index.js'
    env:
      DASHSCOPE_API_KEY: '${QWEN_API_KEY}'
    timeout: 120000

  document-generator:
    type: stdio
    command: node
    args:
      - '/app/mcp-servers/document-generator/index.js'
    env:
      DOCUMENTS_PATH: '/app/client/public/images/documents'
      DOCUMENTS_BASE_URL: '${DOMAIN_CLIENT}'
    timeout: 120000

actions:
  allowedDomains:
    - 'api.anthropic.com'
    - 'api.openai.com'
    - 'dashscope-intl.aliyuncs.com'
    - 'dashscope.aliyuncs.com'
    - 'api.deepseek.com'
    - 'open.bigmodel.cn'
    - 'openrouter.ai'
  allowedAddresses:
    - 'ollama:11434'
    - 'localhost:11434'
    - '127.0.0.1:11434'
