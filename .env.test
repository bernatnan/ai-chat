# Test environment file for LibreChat official image
# Copy this to .env.test and fill in your values

# Server
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080
NO_INDEX=true
TRUST_PROXY=1

# Endpoints
ENDPOINTS=custom,agents

# JWT Secrets (required for LibreChat to start)
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# Credentials encryption (required)
CREDS_KEY=your-creds-key-here
CREDS_IV=your-creds-iv-here

# MongoDB
MONGO_URI=mongodb://mongodb:27017/LibreChat

# Meilisearch
SEARCH=true
MEILI_HOST=http://meilisearch:7700
MEILI_NO_ANALYTICS=true
MEILI_MASTER_KEY=your-meili-master-key-here

# RAG
RAG_PORT=8000
RAG_API_URL=http://rag_api:8000
RAG_OPENAI_BASEURL=http://ollama:11434/v1
RAG_OPENAI_API_KEY=ollama
RAG_USE_FULL_CONTEXT=false
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=nomic-embed-text

# Admin Panel
ADMIN_PANEL_PORT=3000
ADMIN_PANEL_SESSION_SECRET=your-admin-panel-secret-here

# SearXNG
SEARXNG_INSTANCE_URL=http://searxng:8080
SEARXNG_SECRET=your-searxng-secret-here
SEARXNG_LIMITER=false
SEARXNG_PUBLIC_INSTANCE=false

# LocalAI
LOCALAI_PORT=8180
LOCALAI_THREADS=4

# API Keys (fill in your actual keys)
# TAVILY_API_KEY=your-tavily-key
# JINA_API_KEY=your-jina-key
# ANTHROPIC_API_KEY=your-anthropic-key

# Required for RAG API (uses Ollama for embeddings)
OPENAI_API_KEY=your-openai-key
OPENAI_API_BASE=http://ollama:11434/v1

# OpenID (dummy values for admin panel)
OPENID_CLIENT_ID=placeholder
OPENID_CLIENT_SECRET=placeholder
OPENID_ISSUER=http://localhost
OPENID_SCOPE=openid
OPENID_SESSION_SECRET=your-openid-session-secret-here

# Optional: Ollama
OLLAMA_HOST=http://ollama:11434
