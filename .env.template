#=====================================================================#
#                       AI Chat Stack Configuration                   #
#=====================================================================#
# Copia aquest fitxer a .env i edita els valors:
#   cp .env.template .env && nano .env
#
# El setup.sh generarà automàticament els secrets (JWT, Meili, SearXNG)
#=====================================================================#

#==================================================#
#               Server Configuration               #
#==================================================#

HOST=0.0.0.0
PORT=3080

MONGO_URI=mongodb://mongodb:27017/LibreChat

# Canvia-ho pel teu domini real (usa https:// si tens SSL)
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

NO_INDEX=true
TRUST_PROXY=1

#==================================================#
#                    Endpoints                     #
#==================================================#

ENDPOINTS=anthropic

#============#
# Anthropic  #
#============#

ANTHROPIC_API_KEY=user_provided

#============#
# OpenAI     #
#============#

OPENAI_API_KEY=user_provided

#==================================================#
#                      Search                      #
#==================================================#

SEARCH=true
MEILI_NO_ANALYTICS=true
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=GENERATE_MEILI_KEY

#==================================================#
#                  Web Search                      #
#==================================================#

# SearXNG (cerca local)
SEARXNG_INSTANCE_URL=http://searxng:8080
SEARXNG_SECRET=GENERATE_SEARXNG_SECRET

# Tavily (scraper - free tier: 1000 cerques/mes)
# Obtén la teva API key a: https://tavily.com
TAVILY_API_KEY=user_provided

# Jina (reranker - free tier: 10M tokens)
# Obtén la teva API key a: https://jina.ai/api-dashboard/
JINA_API_KEY=user_provided

#==================================================#
#                        RAG                       #
#==================================================#

RAG_API_URL=http://rag_api:8000

#===================================================#
#                    User System                    #
#===================================================#

OPENAI_MODERATION=false
BAN_VIOLATIONS=true
BAN_DURATION=1000 * 60 * 60 * 2
BAN_INTERVAL=20

LOGIN_VIOLATION_SCORE=1
REGISTRATION_VIOLATION_SCORE=1
CONCURRENT_VIOLATION_SCORE=1
MESSAGE_VIOLATION_SCORE=1
NON_BROWSER_VIOLATION_SCORE=20

LOGIN_MAX=7
LOGIN_WINDOW=5
REGISTER_MAX=5
REGISTER_WINDOW=60

LIMIT_CONCURRENT_MESSAGES=true
CONCURRENT_MESSAGE_MAX=2

LIMIT_MESSAGE_IP=true
MESSAGE_IP_MAX=40
MESSAGE_IP_WINDOW=1

LIMIT_MESSAGE_USER=false
MESSAGE_USER_MAX=40
MESSAGE_USER_WINDOW=1

#========================#
# Registration and Login #
#========================#

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_PASSWORD_RESET=true
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

SESSION_EXPIRY=1000 * 60 * 15
REFRESH_TOKEN_EXPIRY=(1000 * 60 * 60 * 24) * 7

# IMPORTANT: El setup.sh generarà aquests secrets automàticament
JWT_SECRET=GENERATE_JWT_SECRET
JWT_REFRESH_SECRET=GENERATE_JWT_REFRESH_SECRET

CREDS_KEY=GENERATE_CREDS_KEY
CREDS_IV=GENERATE_CREDS_IV

# Admin Panel (mínim 32 caràcters, generat automàticament per setup.sh)
ADMIN_PANEL_SESSION_SECRET=GENERATE_ADMIN_PANEL_SECRET

#========================#
# Email / SMTP           #
#========================#

# Descomenta i configura el teu servidor SMTP
# EMAIL_SERVICE=gmail
# EMAIL_HOST=smtp.exemple.com
# EMAIL_PORT=587
# EMAIL_ENCRYPTION=starttls
# EMAIL_USERNAME=usuari@exemple.com
# EMAIL_PASSWORD=contrasenya
# EMAIL_FROM=noreply@exemple.com
# EMAIL_FROM_NAME=LibreChat

#========================#
# Shared Links           #
#========================#

ALLOW_SHARED_LINKS=true
ALLOW_SHARED_LINKS_PUBLIC=false

#===================================================#
#                        UI                         #
#===================================================#

APP_TITLE=LibreChat
HELP_AND_FAQ_URL=https://librechat.ai

#==================================================#
#        Qwen / DashScope (via custom endpoint)    #
#==================================================#

QWEN_API_KEY=user_provided

#==================================================#
#        Zhipu AI / GLM (via custom endpoint)      #
#==================================================#

ZHIPU_API_KEY=user_provided

#==================================================#
#        DeepSeek (via custom endpoint)            #
#==================================================#

DEEPSEEK_API_KEY=user_provided
